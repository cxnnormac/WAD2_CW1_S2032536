
{{> head}}
{{> header}}

<div class="studio-panel p-4 p-md-5 shadow-sm">
  <p class="studio-eyebrow mb-1">You’re in</p>
  <h1 class="h3 studio-page-title mb-2">Booking confirmation</h1>
  <p class="text-secondary mb-4">Your booking has been created.</p>

  <dl class="row mb-4">
    <dt class="col-sm-3">ID</dt><dd class="col-sm-9">{{booking.id}}</dd>
    <dt class="col-sm-3">Type</dt><dd class="col-sm-9">{{booking.type}}</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">{{booking.status}}</dd>
    <dt class="col-sm-3">Created</dt><dd class="col-sm-9">{{booking.createdAt}}</dd>
  </dl>

  <a class="btn btn-primary" href="/courses">Back to courses</a>
</div>

{{> footer}}
