{{> head}}
{{> header}}

<article>
  <h1>Book Session</h1>

  <p class="muted">
    Course: {{course.title}} • Level: {{course.level}} • Type: {{course.type}}
  </p>

  <p>
    Session time: <strong>{{session.start}}</strong>
  </p>
  <p class="muted">
    Capacity: {{session.capacity}} • Booked: {{session.booked}} • Remaining:
    {{session.remaining}}
  </p>

  {{#errors}}
  <div class="alert error" role="alert" aria-live="assertive">
    <ul>
      {{#list}}
      <li>{{.}}</li>
      {{/list}}
    </ul>
  </div>
  {{/errors}}

  <form method="post" action="/sessions/{{session.id}}/book">
    <input type="hidden" name="userId" value="{{user._id}}">

    <fieldset>
      <legend>Your details</legend>

      <div class="field">
        <label for="name">Full name</label>
        <input id="name" name="name" type="text" required value="{{user.name}}">
      </div>

      <div class="field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required value="{{user.email}}">
      </div>

      <div class="field">
        <label for="notes">Notes (injuries, preferences)</label>
        <textarea id="notes" name="notes" rows="4" placeholder="Optional">{{notes}}</textarea>
      </div>
    </fieldset>

    <div class="actions">
      <button class="btn primary" type="submit">Confirm Session Booking</button>
      <a class="btn" href="/courses/{{course.id}}">Cancel</a>
    </div>
  </form>
</article>

{{> footer}}

