
{{> head}}
{{> header}}

<article class="studio-panel p-4 p-md-5 shadow-sm">
  <p class="studio-eyebrow mb-1">Book a course</p>
  <h1 class="h3 studio-page-title mb-1">{{course.title}}</h1>
  <p class="text-secondary mb-2">
    Level: {{course.level}} • Type: {{course.type}} {{#course.allowDropIn}}• Drop-in available{{/course.allowDropIn}}
  </p>
  <p class="mb-2">{{course.description}}</p>
  <p class="text-secondary mb-4">Dates: {{course.startDate}} – {{course.endDate}}</p>

  {{#errors}}
  <div class="alert alert-danger" role="alert" aria-live="assertive">
    <ul>
      {{#list}}
      <li>{{.}}</li>
      {{/list}}
    </ul>
  </div>
  {{/errors}}

  <form method="post" action="/courses/{{course.id}}/book">
    <!-- If you add CSRF later: <input type="hidden" name="_csrf" value="{{csrfToken}}"> -->
    <input type="hidden" name="csrfToken" value="{{csrfToken}}" />

    <div class="row g-3">
      <div class="col-12 col-lg-6">
        <div class="border rounded p-3 bg-body">
          <h2 class="h5 mb-3">Your details</h2>
          <div class="mb-3">
            <label class="form-label" for="name">Full name</label>
            <input class="form-control" id="name" name="name" type="text" required value="{{user.name}}">
          </div>
          <div class="mb-3">
            <label class="form-label" for="email">Email</label>
            <input class="form-control" id="email" name="email" type="email" required value="{{user.email}}">
          </div>
          <div class="mb-3">
            <label class="form-label" for="notes">Notes (injuries, preferences)</label>
            <textarea class="form-control" id="notes" name="notes" rows="4" placeholder="Optional">{{notes}}</textarea>
          </div>
          <div class="form-check">
            <input class="form-check-input" id="consent" name="consent" type="checkbox" required>
            <label class="form-check-label" for="consent">
              I agree to the studio’s booking terms &amp; health disclaimer.
            </label>
          </div>
        </div>
      </div>

      <div class="col-12 col-lg-6">
        <div class="border rounded p-3 bg-body">
          <h2 class="h5 mb-3">Booking summary</h2>
          <p class="mb-2">This booking reserves a seat across <strong>{{sessionsCount}}</strong> sessions:</p>
          <ul class="list-group list-group-flush">
            {{#sessions}}
            <li class="list-group-item d-flex justify-content-between">
              <span>{{start}}</span>
              <span class="text-secondary">{{remaining}} left</span>
            </li>
            {{/sessions}}
          </ul>
        </div>
      </div>
    </div>

    <div class="d-flex gap-2 flex-wrap mt-4">
      <button class="btn btn-primary" type="submit">Confirm Course Booking</button>
      <a class="btn btn-outline-secondary" href="/courses/{{course.id}}">Cancel</a>
    </div>
  </form>
</article>

{{> footer}}
