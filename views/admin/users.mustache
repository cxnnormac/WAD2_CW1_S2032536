{{> head}}
{{> header}}

<h1 class="h3 mb-3">Admin · Users</h1>

<div class="table-responsive bg-body-tertiary border rounded-3">
<table class="table table-striped table-hover align-middle mb-0">
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Role</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    {{#users}}
    <tr>
      <td>{{name}}</td>
      <td>{{email}}</td>
      <td>{{role}}</td>
      <td>
        {{^isSelf}}
          <form method="post" action="/admin/users/{{_id}}/promote" class="d-inline">
            <input type="hidden" name="csrfToken" value="{{csrfToken}}" />
            <button class="btn btn-outline-primary btn-sm" type="submit">Make organiser</button>
          </form>
          <form method="post" action="/admin/users/{{_id}}/instructor" class="d-inline">
            <input type="hidden" name="csrfToken" value="{{csrfToken}}" />
            <button class="btn btn-outline-info btn-sm" type="submit">Make instructor</button>
          </form>
          <form method="post" action="/admin/users/{{_id}}/demote" class="d-inline">
            <input type="hidden" name="csrfToken" value="{{csrfToken}}" />
            <button class="btn btn-outline-secondary btn-sm" type="submit">Make student</button>
          </form>
          <form method="post" action="/admin/users/{{_id}}/delete" class="d-inline" onsubmit="return confirm('Remove this user?');">
            <input type="hidden" name="csrfToken" value="{{csrfToken}}" />
            <button class="btn btn-outline-danger btn-sm" type="submit">Remove</button>
          </form>
        {{/isSelf}}
        {{#isSelf}}
          <span class="text-secondary">This is you</span>
        {{/isSelf}}
      </td>
    </tr>
    {{/users}}
    {{^users}}
      <tr><td colspan="4" class="text-secondary">No users found.</td></tr>
    {{/users}}
  </tbody>
</table>
</div>

<p class="mt-3"><a class="btn btn-outline-secondary" href="/admin">Back</a></p>

{{> footer}}

