{{> head}}
{{> header}}

<h1 class="h3 mb-2">Class list</h1>

<p class="text-secondary mb-1">
  Course: {{#course}}{{title}}{{/course}}{{^course}}(unknown){{/course}}
</p>
<p class="text-secondary mb-3">Session ID: {{session._id}} • Participants: {{participantsCount}}</p>

<div class="table-responsive bg-body-tertiary border rounded-3">
<table class="table table-striped table-hover align-middle mb-0">
  <thead>
    <tr><th>Name</th><th>Email</th><th>Role</th></tr>
  </thead>
  <tbody>
    {{#participants}}
    <tr>
      <td>{{name}}</td>
      <td>{{email}}</td>
      <td>{{role}}</td>
    </tr>
    {{/participants}}
    {{^participants}}
    <tr><td colspan="3" class="text-secondary">No confirmed bookings for this session yet.</td></tr>
    {{/participants}}
  </tbody>
</table>
</div>

<p class="mt-3">
  {{#course}}
    <a class="btn btn-outline-secondary" href="/admin/courses/{{_id}}/edit">Back to course</a>
  {{/course}}
  {{^course}}
    <a class="btn btn-outline-secondary" href="/admin/courses">Back</a>
  {{/course}}
</p>

{{> footer}}

