{{> head}}
{{> header}}

<div class="d-flex align-items-end justify-content-between mb-4 flex-wrap gap-3">
  <div>
    <p class="studio-eyebrow mb-1">Admin</p>
    <h1 class="h3 studio-page-title mb-0">Courses</h1>
  </div>
  <a class="btn btn-primary" href="/admin/courses/new">New course</a>
</div>

<div class="table-responsive studio-table-wrap">
<table class="table table-striped table-hover align-middle mb-0">
  <thead>
    <tr>
      <th>Title</th>
      <th>Level</th>
      <th>Type</th>
      <th>Drop-in</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    {{#courses}}
    <tr>
      <td>{{title}}</td>
      <td>{{level}}</td>
      <td>{{type}}</td>
      <td>{{#allowDropIn}}Yes{{/allowDropIn}}{{^allowDropIn}}No{{/allowDropIn}}</td>
      <td class="text-end"><a class="btn btn-outline-primary btn-sm" href="/admin/courses/{{_id}}/edit">Edit</a></td>
    </tr>
    {{/courses}}
    {{^courses}}
    <tr><td colspan="5" class="text-muted">No courses yet.</td></tr>
    {{/courses}}
  </tbody>
</table>
</div>

{{> footer}}

