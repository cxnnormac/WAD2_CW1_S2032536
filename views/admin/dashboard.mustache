{{> head}}
{{> header}}

<p class="studio-eyebrow mb-2">Organiser</p>
<h1 class="h3 studio-page-title mb-4">Admin</h1>

<div class="row g-4">
  <div class="col-12 col-md-6">
    <article class="card studio-card shadow-sm h-100 border-0">
      <div class="card-body">
        <h2 class="h5 card-title">Courses</h2>
        <p class="text-muted mb-3">Total: {{stats.courses}}</p>
        <a class="btn btn-primary" href="/admin/courses">Manage courses</a>
      </div>
    </article>
  </div>

  <div class="col-12 col-md-6">
    <article class="card studio-card shadow-sm h-100 border-0">
      <div class="card-body">
        <h2 class="h5 card-title">Users</h2>
        <p class="text-muted mb-3">Total: {{stats.users}}</p>
        <a class="btn btn-primary" href="/admin/users">Manage users</a>
      </div>
    </article>
  </div>
</div>

{{> footer}}

