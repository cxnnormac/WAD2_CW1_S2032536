
{{> head}}
{{> header}}

<article>
  <h1>{{course.title}}</h1>
  <p class="muted">
    Level: {{course.level}} • Type: {{course.type}} {{#course.allowDropIn}}• Drop-in available{{/course.allowDropIn}}
  </p>
  <p>{{course.description}}</p>
  <p class="muted">Dates: {{course.startDate}} – {{course.endDate}}</p>

  <section>
    <h2>Book the full course</h2>
    <p>
      <a class="btn primary" href="/courses/{{course.id}}/book">
        Book this course
      </a>
    </p>
  </section>

  <section>
    <h2>Sessions</h2>
    <table class="table">
      <thead>
        <tr><th>Start</th><th>End</th><th>Capacity</th><th>Booked</th><th>Remaining</th><th></th></tr>
      </thead>
      <tbody>
        {{#sessions}}
        <tr>
          <td>{{start}}</td>
          <td>{{end}}</td>
          <td>{{capacity}}</td>
          <td>{{booked}}</td>
          <td>{{remaining}}</td>
          <td>
            {{#../course.allowDropIn}}
              {{#remaining}}
                <a class="btn" href="/sessions/{{id}}/book">Book this session</a>
              {{/remaining}}
              {{^remaining}}
                <span class="muted">Fully booked</span>
              {{/remaining}}
            {{/../course.allowDropIn}}
            {{^../course.allowDropIn}}
              <span class="muted">Drop-ins disabled</span>
            {{/../course.allowDropIn}}
          </td>
        </tr>
        {{/sessions}}
      </tbody>
    </table>
  </section>
</article>

{{> footer}}
