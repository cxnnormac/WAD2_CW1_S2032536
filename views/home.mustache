
{{> head}}
{{> header}}

<section class="mb-4" aria-labelledby="studio-overview">
  <div class="p-4 p-md-5 bg-white border rounded-3">
    <h1 id="studio-overview" class="display-6 fw-semibold mb-3">
      Welcome to our Yoga &amp; Mindfulness Studio
    </h1>
    <p class="lead mb-3">
      We offer small-group yoga and mindfulness classes for all levels, from complete
      beginners to experienced practitioners. Join a weekly block of classes or a
      focused weekend workshop.
    </p>
    <p class="text-muted mb-0">
      Location: 123 Example Street, Glasgow • Studio 2, 3rd Floor
    </p>
  </div>
</section>

<section aria-labelledby="upcoming-courses">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h2 id="upcoming-courses" class="h3 mb-0">Upcoming Courses</h2>
    <a class="btn btn-outline-secondary btn-sm" href="/courses">View all</a>
  </div>

  <div class="row g-3">
    {{#courses}}
    <div class="col-12 col-md-6 col-lg-4">
      <article class="card h-100 shadow-sm">
        <div class="card-body">
          <h3 class="h5 card-title">
            <a class="text-decoration-none" href="/courses/{{id}}">{{title}}</a>
          </h3>
          <p class="text-muted small mb-2">
            Level: {{level}} • Type: {{type}} {{#allowDropIn}}• Drop-in OK{{/allowDropIn}}
          </p>
          <p class="card-text">{{description}}</p>
          <p class="text-muted small mb-1">Dates: {{startDate}} – {{endDate}}</p>
          <p class="text-muted small mb-0">
            Next session: {{nextSession}} • Sessions: {{sessionsCount}}
          </p>
        </div>
        <div class="card-footer bg-transparent border-0 pt-0">
          <a class="btn btn-primary w-100" href="/courses/{{id}}">View details &amp; book</a>
        </div>
      </article>
    </div>
    {{/courses}}

    {{^courses}}
      <div class="col-12">
        <div class="alert alert-info mb-0">No courses available yet.</div>
      </div>
    {{/courses}}
  </div>
</section>

{{> footer}}
