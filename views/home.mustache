
{{> head}}
{{> header}}

<section class="mb-4" aria-labelledby="studio-overview">
  <div class="p-4 p-md-5 bg-body-tertiary border rounded-3">
    <h1 id="studio-overview" class="display-6 fw-semibold mb-3">
      Welcome to our Yoga &amp; Mindfulness Studio
    </h1>
    <p class="lead mb-3">
      We are a small, independent studio offering yoga and mindfulness classes for all
      levels of fitness and experience. You can join a short weekend workshop or commit
      to a longer block of weekly classes, depending on what suits your schedule.
    </p>
    <div class="row g-3 mb-3">
      <div class="col-12 col-md-6">
        <h2 class="h5">What we offer</h2>
        <ul class="mb-0">
          <li>Gentle and restorative classes for complete beginners</li>
          <li>Stronger flow classes for more experienced practitioners</li>
          <li>Mindfulness and breathing sessions to support stress management</li>
          <li>Weekend workshops with multiple sessions over two days</li>
        </ul>
      </div>
      <div class="col-12 col-md-6">
        <h2 class="h5">Where to find us</h2>
        <p class="mb-2">
          Our classes run at:
        </p>
        <p class="mb-1">
          <strong>Yoga &amp; Mindfulness Studio at Glasgow Caledonian University</strong><br />
          Glasgow Caledonian University<br />
          Cowcaddens Road<br />
          Glasgow G4 0BA<br />
          Campus studio space (lift access available)
        </p>
        <p class="mb-0 text-secondary">
          Please arrive 10 minutes early to get settled and let the instructor know about
          any injuries or access needs.
        </p>
      </div>
    </div>
  </div>
</section>

<section aria-labelledby="upcoming-courses">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h2 id="upcoming-courses" class="h3 mb-0">Upcoming Courses</h2>
    <a class="btn btn-outline-secondary btn-sm" href="/courses">View all</a>
  </div>

  <div class="row g-3">
    {{#courses}}
    <div class="col-12 col-md-6 col-lg-4">
      <article class="card h-100 shadow-sm">
        <div class="card-body">
          <h3 class="h5 card-title">
            <a class="text-decoration-none" href="/courses/{{id}}">{{title}}</a>
          </h3>
          <p class="text-muted small mb-2">
            Level: {{level}} • Type: {{type}} {{#allowDropIn}}• Drop-in OK{{/allowDropIn}}
          </p>
          <p class="card-text">{{description}}</p>
          <p class="text-muted small mb-1">Dates: {{startDate}} – {{endDate}}</p>
          <p class="text-muted small mb-1">
            Location: {{location}}
          </p>
          <p class="text-muted small mb-0">
            Price: £{{price}} • Next session: {{nextSession}} • Sessions: {{sessionsCount}}
          </p>
        </div>
        <div class="card-footer bg-transparent border-0 pt-0">
          <a class="btn btn-primary w-100" href="/courses/{{id}}">View details &amp; book</a>
        </div>
      </article>
    </div>
    {{/courses}}

    {{^courses}}
      <div class="col-12">
        <div class="alert alert-info mb-0">No courses available yet.</div>
      </div>
    {{/courses}}
  </div>
</section>

{{> footer}}
